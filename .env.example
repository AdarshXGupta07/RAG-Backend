# Supabase Database Configuration
DB_HOST=your_supabase_db_host
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_supabase_db_password

# JWT Authentication Config
SECRET_KEY=your_jwt_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=300

# Rate Limiting (Redis / Upstash URL)
# Fallback is in-memory "memory://" if left blank
REDIS_URL=redis://localhost:6379

# CORS Allowed Origins (Comma separated URLs for deployed frontends)
# Example: CORS_ORIGINS=https://your-frontend.netlify.app,http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# External AI Service Keys
JINA_API_KEY=your_jina_api_key_here
GROQ_API_KEY=your_groq_api_key_here
